# ============================================================
# Supabase — configuração da ficha de anamnese e do painel
# Copie para um arquivo .env (que NÃO vai para o git) e preencha.
# Em produção (Lovable/Cloudflare), defina como variáveis de ambiente.
# ============================================================

# Público (pode ir para o navegador — protegido pelo RLS).
# Encontre em: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# SECRETO — só no servidor. Nunca use o prefixo VITE_ aqui.
# É a chave que grava as fichas (ignora o RLS). Não exponha.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...
